Bootstrap: localimage
From: neko_base.sif

%environment
export DEBIAN_FRONTEND=noninteractive
export PREFIX=${APPTAINER_ROOTFS}/neko_install
export PKG_CONFIG_PATH=$PREFIX/lib/pkgconfig:$PKG_CONFIG_PATH
export LD_LIBRARY_PATH=$PREFIX/lib:$LD_LIBRARY_PATH
export FC=gfortran

%post
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y ocl-icd-opencl-dev opencl-c-headers opencl-clhpp-headers

%runscript
    set -e
    export CC=gcc
    export CXX=g++
    export FC=gfortran
    mkdir -p /tmp/neko_build/opencl
    rm -rf /tmp/neko_build/opencl/*
    cp -aL /neko/. /tmp/neko_build/opencl/
    mkdir -p /tmp/neko_build/opencl/install
    cd /tmp/neko_build/opencl
    ./regen.sh
    ./configure CC=${CC} CXX=${CXX} FC=${FC} FCFLAGS="-O2 -pedantic -std=f2008 -w" --with-opencl=/usr --with-hdf5=$PREFIX --prefix=/tmp/neko_build/opencl/install
    make -j"$(nproc)" install
